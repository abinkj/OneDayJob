{
  "expo": {
    "name": "Zoopol",
    "slug": "zoopol",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/819389f1-6170-4df9-b735-9831e39f5b21",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#294678"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zoopol1.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["tel", "mailto", "sms"]
      }
    },
    "scheme": "zoopol",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#294678"
      },
      "package": "com.zoopol1.app",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location to help find nearby jobs and provide accurate navigation to job sites.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location to show available jobs in your immediate area."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#294678",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID for secure authentication to your account."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to let you upload a profile picture and add relevant photos to job listings.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take a profile picture or document job-related tasks."
        }
      ],
      "expo-web-browser"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#ffffff",
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new interactions"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "819389f1-6170-4df9-b735-9831e39f5b21"
      }
    },
    "owner": "zoopol"
  }
}
